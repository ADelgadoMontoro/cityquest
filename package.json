{
  "name": "cityquest",
  "version": "0.1.0",
  "private": true,
  "description": "CityQuest monorepo for the mobile app, admin panel, API, infrastructure, and shared packages.",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/contexts/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "typecheck": "npm run typecheck:repo && npm run typecheck:workspaces",
    "typecheck:repo": "tsc -p tsconfig.json --noEmit",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
