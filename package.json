{
  "name": "cityquest",
  "version": "0.1.0",
  "private": true,
  "description": "CityQuest monorepo for the mobile app, admin panel, API, infrastructure, and shared packages.",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "workspaces": [
    "apps/*",
    "infra",
    "packages/*",
    "packages/contexts/*"
  ],
  "scripts": {
    "api:deploy": "npm run deploy --workspace @cityquest/api",
    "api:dev": "npm run dev --workspace @cityquest/api",
    "build": "npm run build:admin && npm run build:api && npm run build:infra",
    "build:admin": "npm run build --workspace @cityquest/admin",
    "build:api": "npm run build --workspace @cityquest/api",
    "build:infra": "npm run build --workspace @cityquest/infra",
    "check:pre-commit": "npm run lint",
    "check:pre-push": "npm run test && npm run typecheck",
    "clean": "npm run clean --workspaces --if-present",
    "cf:login": "npm run login --workspace @cityquest/api",
    "cf:whoami": "npm run whoami --workspace @cityquest/api",
    "dev": "concurrently -n mobile,admin,api \"npm run dev:mobile\" \"npm run dev:admin\" \"npm run dev:api\"",
    "dev:admin": "npm run dev --workspace @cityquest/admin",
    "dev:api": "npm run dev --workspace @cityquest/api",
    "dev:mobile": "npm run dev --workspace @cityquest/mobile",
    "d1:list": "npm run d1:list --workspace @cityquest/api",
    "d1:migrations:apply:local": "npm run d1:migrations:apply:local --workspace @cityquest/api",
    "d1:migrations:apply:remote": "npm run d1:migrations:apply:remote --workspace @cityquest/api",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prepare": "node ./scripts/configure-git-hooks.mjs",
    "test": "npm run test:api && npm run test:infra && npm run test:mobile",
    "test:api": "npm run test --workspace @cityquest/api",
    "test:infra": "npm run test --workspace @cityquest/infra",
    "test:integration": "npm run test:integration --workspace @cityquest/api && npm run test:integration --workspace @cityquest/mobile",
    "test:mobile": "npm run test --workspace @cityquest/mobile",
    "test:unit": "npm run test:unit --workspace @cityquest/api && npm run test:unit --workspace @cityquest/infra && npm run test:unit --workspace @cityquest/mobile",
    "typecheck": "npm run typecheck:repo && npm run typecheck:workspaces",
    "typecheck:repo": "tsc -p tsconfig.json --noEmit",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
