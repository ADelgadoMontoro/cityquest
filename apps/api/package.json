{
  "name": "@cityquest/api",
  "version": "0.1.0",
  "private": true,
  "description": "CityQuest Cloudflare Workers API workspace.",
  "scripts": {
    "build": "npm run build:types && npm run build:worker",
    "build:types": "tsc -p tsconfig.build.json",
    "build:worker": "node ./scripts/verify-worker-runtime.mjs",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true }); require('fs').rmSync('.wrangler', { recursive: true, force: true }); require('fs').rmSync('.wrangler-home', { recursive: true, force: true })\"",
    "dev": "node ./scripts/run-wrangler.mjs dev",
    "d1:list": "node ./scripts/run-wrangler.mjs d1 list",
    "d1:migrations:apply:local": "node ./scripts/run-wrangler.mjs d1 migrations apply cityquest-dev-db --local",
    "d1:migrations:apply:remote": "node ./scripts/run-wrangler.mjs d1 migrations apply cityquest-dev-db --remote",
    "deploy": "node ./scripts/run-wrangler.mjs deploy",
    "format": "prettier --check . --ignore-unknown",
    "format:write": "prettier --write . --ignore-unknown",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "login": "node ./scripts/run-wrangler.mjs login",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "whoami": "node ./scripts/run-wrangler.mjs whoami"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "wrangler": "4.97.0"
  }
}
