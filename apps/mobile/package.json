{
  "name": "@cityquest/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "CityQuest Expo mobile application.",
  "main": "index.ts",
  "scripts": {
    "android": "expo start --android",
    "build": "echo \"Mobile production builds will be added in a later task.\"",
    "clean": "echo \"Nothing to clean in apps/mobile yet.\"",
    "dev": "expo start",
    "format": "prettier --check . --ignore-unknown",
    "format:write": "prettier --write . --ignore-unknown",
    "ios": "expo start --ios",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "start": "expo start",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~56.0.5",
    "expo-status-bar": "~3.0.8",
    "react": "19.2.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.2.2"
  }
}
