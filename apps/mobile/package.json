{
  "name": "@cityquest/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "CityQuest Expo mobile application.",
  "main": "index.ts",
  "scripts": {
    "android": "expo run:android",
    "build": "echo \"Mobile production builds will be added in a later task.\"",
    "clean": "echo \"Nothing to clean in apps/mobile yet.\"",
    "dev": "expo start",
    "format": "prettier --check . --ignore-unknown",
    "format:write": "prettier --write . --ignore-unknown",
    "ios": "expo run:ios",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "start": "expo start",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~56.0.5",
    "expo-dev-client": "~56.0.19",
    "expo-image-picker": "~56.0.16",
    "expo-location": "~56.0.16",
    "expo-status-bar": "~3.0.8",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.15"
  }
}
